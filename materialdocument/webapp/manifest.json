{
  "_version": "1.65.0",
  "sap.app": {
    "id": "materialdocument",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.17.6",
      "toolsId": "ebacc42b-9fe6-404a-9a7b-3e70dffdb1e3"
    },
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata/sap/API_MATERIAL_DOCUMENT_SRV/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      },
      "TemplateJSONData": {
        "uri": "model/template.json",
        "type": "JSON"
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.130.10",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "materialdocument.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {}
      },
      "templateModel": {
        "type": "sap.ui.model.json.JSONModel",
        "dataSource": "TemplateJSONData"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "materialdocument.view",
        "async": true,
        "viewPath": "materialdocument.view"
      },
      "routes": [
        {
          "name": "RouteUpload_Material",
          "pattern": ":?query:",
          "target": [
            "TargetUpload_Material"
          ]
        }
      ],
      "targets": {
        "TargetUpload_Material": {
          "id": "Upload_Material",
          "name": "Upload_Material"
        }
      }
    },
    "rootView": {
      "viewName": "materialdocument.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
